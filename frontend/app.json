{
  "expo": {
    "name": "JASPR",
    "slug": "jaspr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jaspr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jaspr.wallet"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jaspr.wallet"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "jaspr-wallet"
      },
      "supabaseUrl": "${EXPO_PUBLIC_SUPABASE_URL}",
      "supabaseAnonKey": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
      "backendUrl": "${EXPO_PUBLIC_BACKEND_URL}",
      "baseSepoliaRpc": "${EXPO_PUBLIC_BASE_SEPOLIA_RPC}",
      "baseSepoliaChainId": "${EXPO_PUBLIC_BASE_SEPOLIA_CHAIN_ID}",
      "baseExplorer": "${EXPO_PUBLIC_BASE_EXPLORER}"
    },
    "owner": "jaspr"
  }
}
